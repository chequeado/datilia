FROM python:3.11-slim

# git is required for the draco git-source dependency and to clone data360-mcp
RUN apt-get update && apt-get install -y --no-install-recommends git curl && \
    rm -rf /var/lib/apt/lists/*

RUN pip install --no-cache-dir uv

WORKDIR /mcp
RUN git clone --depth=1 https://github.com/worldbank/data360-mcp.git . 2>&1

# Sync production deps only (dev group includes data360-mcp-agent workspace member)
RUN uv sync --no-dev

EXPOSE 8000

ENV MCP_PORT=8000
ENV MCP_TRANSPORT=streamable-http
ENV UVICORN_WORKERS=2

CMD ["uv", "run", "uvicorn", "data360.server:app", "--host", "0.0.0.0", "--port", "8000"]
