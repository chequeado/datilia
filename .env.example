# OpenAI 
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-5.4
LLM_TEMPERATURE=0.1

# MCP server (overridden to http://mcp:8000/mcp inside Docker)
MCP_SERVER_URL=http://localhost:8000/mcp
MCP_TRANSPORT=http

# data360-mcp required config (passed to the mcp container)
DATA360_API_BASE_URL=https://data360api.worldbank.org

# Tool-use loop
MAX_TOOL_TURNS=8
REQUEST_TIMEOUT_SECONDS=120

# Django
DJANGO_SECRET_KEY=change-me-in-production
DJANGO_DEBUG=True
ALLOWED_HOSTS=*
CORS_ALLOWED_ORIGINS=*

# DataWrapper
DATAWRAPPER_API_KEY=your-datawrapper-api-key-here
